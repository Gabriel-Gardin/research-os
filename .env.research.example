# .env.research.example
# Copie para .env.research e preencha os valores reais.
# Este arquivo pode ser commitado. .env.research NÃO deve ser commitado.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Ingestão ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512          # tokens por chunk
CHUNK_OVERLAP=64        # overlap entre chunks consecutivos
IMPORTS_DIR=./imports   # pasta local monitorada pelo worker

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_PORT=8080
# "sse"   → servidor HTTP acessível via URL (Claude.ai remote MCP, n8n, etc.)
# "stdio" → stdin/stdout (Claude Desktop local)
MCP_TRANSPORT=sse

# ── Opcional: logs ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
